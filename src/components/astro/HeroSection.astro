---
// HeroSection.astro — Cinematic full-screen intro
---

<section class="relative h-screen w-full overflow-hidden bg-navy">
  <!-- Background Image with Dark Overlay -->
  <div class="absolute inset-0">
    <img 
      src="/images/hero-bg.jpeg" 
      alt="Photography background"
      class="w-full h-full object-cover opacity-40"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/60 via-transparent to-navy/80"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 h-full flex flex-col items-center justify-center px-6 text-center">
    <!-- Small Label -->
    <p class="hero-animate font-sans text-sage text-xs tracking-[0.3em] uppercase mb-6">
      Visual Storyteller
    </p>
    
    <!-- Main Title -->
    <h1 class="hero-animate font-serif text-cream text-5xl md:text-7xl lg:text-9xl font-light tracking-tight leading-none mb-8">
      Koba<span class="text-earth">Photography</span>
    </h1>
    
    <!-- Tagline -->
    <p class="hero-animate font-sans text-sage/80 text-sm md:text-base tracking-wide max-w-md">
      Every frame tells a story. Every story becomes timeless.
    </p>

    <!-- Scroll Indicator -->
    <div class="hero-animate absolute bottom-12 left-1/2 -translate-x-1/2">
      <div class="w-px h-16 bg-gradient-to-b from-sage/50 to-transparent mx-auto mb-2"></div>
      <p class="text-sage/50 text-[10px] tracking-[0.2em] uppercase">Scroll</p>
    </div>
  </div>
</section>

<style>
  .hero-animate {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1.2s ease-out, transform 1.2s ease-out;
  }

  /* When page is loaded, animate hero elements with stagger */
  :global(.page-loaded) .hero-animate:nth-child(1) { 
    opacity: 1; 
    transform: translateY(0); 
    transition-delay: 0.3s; 
  }
  :global(.page-loaded) .hero-animate:nth-child(2) { 
    opacity: 1; 
    transform: translateY(0); 
    transition-delay: 0.6s; 
  }
  :global(.page-loaded) .hero-animate:nth-child(3) { 
    opacity: 1; 
    transform: translateY(0); 
    transition-delay: 0.9s; 
  }
  :global(.page-loaded) .hero-animate:nth-child(4) { 
    opacity: 1; 
    transform: translateY(0); 
    transition-delay: 1.2s; 
  }
</style>