---
// Footer.astro — Cinematic footer
const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-navy text-cream relative overflow-hidden">
  <!-- Top decorative line -->
  <div class="w-full h-px bg-gradient-to-r from-transparent via-earth/50 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 py-20 md:py-28">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      
      <!-- Brand Column -->
      <div class="md:col-span-5">
        <a href="/" class="flex items-center gap-3 mb-6">
          <img 
            src="/images/logo.png" 
            alt="KobaPhotography" 
            class="h-12 w-auto"
            style="filter: brightness(0) invert(1);"
          />
          <span class="font-serif text-2xl font-light tracking-tight text-cream">
            Koba<span class="text-earth">Photography</span>
          </span>
        </a>
        <p class="font-sans text-sage/60 text-sm leading-relaxed max-w-sm">
          Capturing the raw, unscripted moments that make every story unforgettable. Based in Sri Lanka, available worldwide.
        </p>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-3 md:col-start-7">
        <h4 class="font-sans text-xs tracking-[0.3em] uppercase text-sage/40 mb-6">Navigate</h4>
        <ul class="space-y-3">
          <li><a href="#stories" class="font-serif text-lg text-cream/70 hover:text-cream transition-colors duration-300">Stories</a></li>
          <li><a href="#portfolio" class="font-serif text-lg text-cream/70 hover:text-cream transition-colors duration-300">Portfolio</a></li>
          <li><a href="#about" class="font-serif text-lg text-cream/70 hover:text-cream transition-colors duration-300">About</a></li>
          <li><a href="#contact" class="font-serif text-lg text-cream/70 hover:text-cream transition-colors duration-300">Contact</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div class="md:col-span-3">
        <h4 class="font-sans text-xs tracking-[0.3em] uppercase text-sage/40 mb-6">Connect</h4>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:text-cream hover:border-earth hover:bg-earth/10 transition-all duration-300" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:text-cream hover:border-earth hover:bg-earth/10 transition-all duration-300" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full border border-cream/20 flex items-center justify-center text-cream/60 hover:text-cream hover:border-earth hover:bg-earth/10 transition-all duration-300" aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-cream/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-sans text-xs text-sage/40 tracking-wide">
        &copy; {currentYear} KobaPhotography. All rights reserved.
      </p>
      <p class="font-sans text-xs text-sage/40 tracking-wide">
        Crafted with passion for visual storytelling
      </p>
    </div>
  </div>
</footer>