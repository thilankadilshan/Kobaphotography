---
// src/pages/story/[slug].astro
// Individual story page — hero (navy) → details (warm cream) → gallery (sage tint)

import BaseLayout from '../../layouts/BaseLayout.astro';
import { stories, getStoryBySlug } from '../../data/stories.js';

export function getStaticPaths() {
  return stories.map(story => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;

if (!story) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${story.couple} | KobaPhotography`}>
  <div class="story-page">
    
    <!-- ==================== HERO SECTION (Navy — Cinematic) ==================== -->
    <section class="relative h-screen w-full overflow-hidden" style="background-color: #0A2947;">
      <!-- Background image with Ken Burns effect -->
      <div class="absolute inset-0 ken-burns-container">
        <img 
          src={story.coverImage} 
          alt={story.couple}
          class="w-full h-full object-cover ken-burns-image"
          onerror="this.src='/images/hero-bg.jpeg'"
        />
        <div class="absolute inset-0 bg-linear-to-t from-[#0A2947] via-[#0A2947]/40 to-[#0A2947]/20"></div>
        <div class="absolute inset-0 bg-linear-to-r from-[#0A2947]/80 via-transparent to-transparent"></div>
      </div>

      <!-- Hero Content -->
      <div class="relative z-10 h-full flex flex-col justify-end pb-20 md:pb-32 px-6 md:px-12 max-w-7xl mx-auto">
        <div class="max-w-2xl">
          <p class="font-sans text-[#D3D4C0]/70 text-xs tracking-[0.4em] uppercase mb-4 story-fade-in">
            {story.category} — {story.date}
          </p>
          <h1 class="font-serif text-cream text-4xl md:text-6xl lg:text-7xl font-light leading-tight mb-4 story-fade-in story-delay-1">
            {story.title}
          </h1>
          <p class="font-sans text-cream/60 text-lg md:text-xl font-light story-fade-in story-delay-2">
            {story.subtitle}
          </p>
          
          <!-- Scroll indicator -->
          <div class="mt-12 flex items-center gap-3 story-fade-in story-delay-3">
            <div class="w-8 h-px bg-[#8B5E3C]/60"></div>
            <span class="font-sans text-[#D3D4C0]/50 text-[10px] tracking-[0.3em] uppercase">Scroll to explore</span>
          </div>
        </div>
      </div>

      <!-- Back button -->
      <a 
        href="/stories" 
        class="fixed top-24 left-6 md:left-12 z-50 flex items-center gap-2 text-cream/60 hover:text-cream transition-colors duration-300 group"
      >
        <span class="w-8 h-8 rounded-full border border-cream/20 flex items-center justify-center group-hover:border-[#8B5E3C] group-hover:bg-[#8B5E3C]/10 transition-all duration-300">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </span>
        <span class="font-sans text-xs tracking-[0.2em] uppercase hidden md:block">Back to Stories</span>
      </a>
    </section>

    <!-- ==================== COLOR TRANSITION BAR ==================== -->
    <div class="relative h-24 overflow-hidden" style="background-color: #0A2947;">
      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(to right, transparent, #8B5E3C, transparent);"></div>
      <!-- Decorative curve transition -->
      <div class="absolute bottom-0 left-0 right-0">
        <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <path d="M0 60V30C240 0 480 0 720 20C960 40 1200 40 1440 20V60H0Z" fill="#F3E4C9"/>
        </svg>
      </div>
    </div>

    <!-- ==================== STORY DETAILS SECTION (Warm Cream) ==================== -->
    <section class="relative py-20 md:py-32 overflow-hidden" style="background-color: #F3E4C9;">
      <!-- Subtle texture -->
      <div class="absolute inset-0 opacity-[0.03]" 
           style="background-image: url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%230A2947%22 fill-opacity=%221%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
      ></div>

      <!-- Decorative glow -->
      <div class="absolute top-20 right-10 w-72 h-72 rounded-full opacity-15 blur-3xl" style="background-color: #D3D4C0;"></div>
      <div class="absolute bottom-10 left-20 w-48 h-48 rounded-full opacity-10 blur-3xl" style="background-color: #8B5E3C;"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-12">
        
        <!-- Section Label -->
        <div class="text-center mb-16 md:mb-20">
          <p class="font-sans text-[10px] tracking-[0.4em] uppercase mb-4" style="color: #8B5E3C;">
            The Narrative
          </p>
          <div class="w-16 h-px mx-auto" style="background: linear-gradient(to right, transparent, #8B5E3C, transparent);"></div>
        </div>

        <!-- Couple Highlight — Big Names -->
        <div class="text-center mb-16 md:mb-20 detail-reveal">
          <p class="font-sans text-[10px] tracking-[0.3em] uppercase mb-4" style="color: rgba(10, 41, 71, 0.4);">
            Featuring
          </p>
          <h2 class="font-serif text-5xl md:text-7xl lg:text-8xl font-light italic leading-none" style="color: #0A2947;">
            {story.couple}
          </h2>
          <div class="flex items-center justify-center gap-4 mt-6">
            <div class="w-12 h-px" style="background-color: #8B5E3C;"></div>
            <p class="font-sans text-xs tracking-[0.2em] uppercase" style="color: #8B5E3C;">{story.category}</p>
            <div class="w-12 h-px" style="background-color: #8B5E3C;"></div>
          </div>
        </div>

        <!-- Story Text — Editorial style -->
        <div class="detail-reveal mb-20 md:mb-28">
          <div class="relative pl-6 md:pl-10 border-l-2" style="border-color: rgba(139, 94, 60, 0.3);">
            <p class="font-sans text-[10px] tracking-[0.3em] uppercase mb-6" style="color: #8B5E3C;">
              Their Story
            </p>
            <div class="font-serif text-xl md:text-2xl lg:text-3xl leading-relaxed font-light" style="color: #0A2947;">
              {story.story.split('\n').map((para, i) => (
                <p class="story-para detail-para mb-6" style="color: rgba(10, 41, 71, 0.85);">{para}</p>
              ))}
            </div>
          </div>
        </div>

        <!-- Credits — Elegant table -->
        <div class="detail-reveal mb-16 md:mb-20">
          <div class="max-w-lg mx-auto">
            <p class="font-sans text-[10px] tracking-[0.3em] uppercase mb-8 text-center" style="color: #8B5E3C;">
              Credits
            </p>
            <div class="space-y-0">
              {story.credits.map((credit, i) => (
                <div class="flex justify-between items-center py-4" style={`border-bottom: ${i < story.credits.length - 1 ? '1px solid rgba(10, 41, 71, 0.08)' : 'none'};`}>
                  <span class="font-sans text-sm tracking-wide" style="color: rgba(10, 41, 71, 0.5);">{credit.role}</span>
                  <span class="font-sans text-sm font-medium" style="color: #0A2947;">{credit.name}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Location & Date — Centered elegant -->
        <div class="detail-reveal text-center">
          <div class="inline-flex items-center gap-8 px-8 py-4 rounded-full" style="background-color: rgba(10, 41, 71, 0.04); border: 1px solid rgba(10, 41, 71, 0.08);">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" style="color: #8B5E3C;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="font-sans text-xs tracking-wide" style="color: rgba(10, 41, 71, 0.6);">{story.location}</span>
            </div>
            <div class="w-px h-4" style="background-color: rgba(10, 41, 71, 0.15);"></div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" style="color: #8B5E3C;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span class="font-sans text-xs tracking-wide" style="color: rgba(10, 41, 71, 0.6);">{story.date}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== COLOR TRANSITION TO GALLERY ==================== -->
    <div class="relative h-20 overflow-hidden" style="background-color: #F3E4C9;">
      <div class="absolute bottom-0 left-0 right-0">
        <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <path d="M0 0V30C240 60 480 60 720 40C960 20 1200 20 1440 40V0H0Z" fill="#D3D4C0"/>
        </svg>
      </div>
    </div>

    <!-- ==================== PHOTO GALLERY SECTION (Sage Tint) ==================== -->
    <section class="relative py-20 md:py-32 overflow-hidden" style="background-color: #D3D4C0;">
      <!-- Gallery Header -->
      <div class="max-w-7xl mx-auto px-6 md:px-12 mb-16 md:mb-20">
        <div class="text-center">
          <p class="font-sans text-[10px] tracking-[0.4em] uppercase mb-4" style="color: #8B5E3C;">
            Visual Journey
          </p>
          <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light tracking-tight" style="color: #0A2947;">
            The <span class="italic" style="color: #8B5E3C;">Gallery</span>
          </h2>
          <div class="w-16 h-px mx-auto mt-6" style="background: linear-gradient(to right, transparent, #8B5E3C, transparent);"></div>
        </div>
      </div>

      <!-- Photo Grid — Masonry feel -->
      <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
          {story.images.map((image, i) => (
            <div class={`gallery-image-reveal relative overflow-hidden rounded-sm group ${i === 0 ? 'md:col-span-2' : ''}`}>
              <div class={`relative overflow-hidden ${i === 0 ? 'aspect-21/9' : 'aspect-4/3'}`}>
                <img 
                  src={image} 
                  alt={`${story.couple} — Photo ${i + 1}`}
                  class="w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-105"
                  loading="lazy"
                  onerror="this.src='/images/hero-bg.jpeg'"
                />
                <!-- Subtle overlay on hover -->
                <div class="absolute inset-0 bg-[#0A2947]/0 group-hover:bg-[#0A2947]/10 transition-all duration-700"></div>
                
                <!-- Photo number badge -->
                <div class="absolute top-4 left-4">
                  <span class="font-sans text-[10px] tracking-[0.2em] uppercase px-3 py-1.5 rounded-full" style="background-color: rgba(10, 41, 71, 0.8); color: #F3E4C9;">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                </div>

                <!-- Corner frame accents on hover -->
                <div class="absolute top-4 right-4 w-10 h-10 border-t-2 border-r-2 opacity-0 group-hover:opacity-100 transition-all duration-500" style="border-color: #F3E4C9;"></div>
                <div class="absolute bottom-4 left-4 w-10 h-10 border-b-2 border-l-2 opacity-0 group-hover:opacity-100 transition-all duration-500" style="border-color: #F3E4C9;"></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Gallery bottom quote -->
      <div class="max-w-3xl mx-auto px-6 md:px-12 mt-20 md:mt-28 text-center">
        <p class="font-serif text-2xl md:text-3xl font-light italic leading-relaxed" style="color: rgba(10, 41, 71, 0.5);">
          "Every photograph is a story frozen in time."
        </p>
        <div class="w-8 h-px mx-auto mt-6" style="background-color: #8B5E3C;"></div>
      </div>
    </section>

    <!-- ==================== NAVIGATION FOOTER (Back to Navy) ==================== -->
    <section class="relative py-16 md:py-24 overflow-hidden" style="background-color: #0A2947;">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(to right, transparent, #8B5E3C, transparent);"></div>
      
      <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
          <div>
            <p class="font-sans text-[#D3D4C0]/50 text-xs tracking-[0.3em] uppercase mb-3">Continue Exploring</p>
            <a href="/stories" class="font-serif text-cream text-2xl md:text-3xl font-light hover:text-[#8B5E3C] transition-colors duration-300">
              View All Stories
            </a>
          </div>
          <a 
            href="/stories"
            class="group flex items-center gap-3 px-6 py-3 border border-cream/20 rounded-full hover:border-[#8B5E3C] hover:bg-[#8B5E3C]/10 transition-all duration-300"
          >
            <span class="font-sans text-cream/70 text-sm tracking-wide group-hover:text-cream transition-colors">Browse Collection</span>
            <svg class="w-4 h-4 text-cream/50 group-hover:text-[#8B5E3C] transition-all duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Ken Burns animation for hero image */
  .ken-burns-container {
    overflow: hidden;
  }
  
  .ken-burns-image {
    animation: kenBurns 20s ease-in-out infinite alternate;
  }
  
  @keyframes kenBurns {
    0% {
      transform: scale(1) translate(0, 0);
    }
    100% {
      transform: scale(1.15) translate(-2%, -1%);
    }
  }

  /* Story fade-in animations */
  .story-fade-in {
    opacity: 0;
    transform: translateY(30px);
    animation: storyFadeIn 1s ease-out forwards;
  }
  
  .story-delay-1 { animation-delay: 0.3s; }
  .story-delay-2 { animation-delay: 0.6s; }
  .story-delay-3 { animation-delay: 0.9s; }
  
  @keyframes storyFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Detail reveal animations */
  .detail-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
  
  .detail-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Paragraph stagger in details */
  .story-para {
    opacity: 0;
    transform: translateY(20px);
  }
  
  .story-para.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  /* Gallery image reveal */
  .gallery-image-reveal {
    opacity: 0;
    transform: translateY(50px) scale(0.98);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }
  
  .gallery-image-reveal.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      threshold: 0.12,
      rootMargin: '0px 0px -60px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Detail sections
    document.querySelectorAll('.detail-reveal').forEach(el => observer.observe(el));
    
    // Story paragraphs with stagger
    document.querySelectorAll('.story-para').forEach((el, i) => {
      el.style.transitionDelay = `${i * 0.2}s`;
      observer.observe(el);
    });
    
    // Gallery images with stagger
    document.querySelectorAll('.gallery-image-reveal').forEach((el, i) => {
      el.style.transitionDelay = `${i * 0.15}s`;
      observer.observe(el);
    });
  });
</script>