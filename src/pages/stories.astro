---
// src/pages/stories.astro
// All stories collection page — cinematic masonry grid

import BaseLayout from '../layouts/BaseLayout.astro';
import { stories } from '../data/stories.js';

const categories = [...new Set(stories.map(s => s.category))];
---

<BaseLayout title="All Stories | KobaPhotography">
  <div class="stories-archive">
    
    <!-- Hero Header — CHANGED TO WARM CREAM -->
    <section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden" style="background-color: #0A2947;">
      <!-- Background texture -->
      <div class="absolute inset-0 opacity-[0.03]" 
           style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"
      ></div>

      <!-- Decorative glow -->
      <div class="absolute top-10 right-20 w-64 h-64 rounded-full opacity-15 blur-3xl" style="background-color: #e3d6d6;"></div>
      <div class="absolute bottom-10 left-10 w-48 h-48 rounded-full opacity-10 blur-3xl" style="background-color: #f1efee;"></div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 text-center">
        <p class="font-sans text-xs tracking-[0.4em] uppercase mb-4 archive-fade-in" style="color: #8B5E3C;">
          Collection
        </p>
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-light tracking-tight leading-none mb-6 archive-fade-in archive-delay-1" style="color: #788050;">
          All <span class="italic" style="color: #8B5E3C;">Stories</span>
        </h1>
        <p class="font-sans text-base md:text-lg max-w-md mx-auto archive-fade-in archive-delay-2" style="color: rgb(196, 203, 209);">
          Every frame holds a memory. Every memory tells a story.
        </p>
        
        <!-- Decorative line -->
        <div class="w-16 h-px mx-auto mt-10 archive-fade-in archive-delay-3" style="background: linear-gradient(to right, transparent, #8B5E3C, transparent);"></div>
      </div>
    </section>

    <!-- Filter Bar — CHANGED TO CREAM -->
    <section class="border-b sticky top-16 z-40" style="background-color: #F3E4C9; border-color: rgba(10, 41, 71, 0.1);">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-4">
        <div class="flex items-center gap-4 overflow-x-auto scrollbar-hide">
          <button 
            class="filter-btn active font-sans text-xs tracking-[0.2em] uppercase px-4 py-2 rounded-full border transition-all duration-300 whitespace-nowrap"
            style="border-color: #8B5E3C; color: #0A2947; background: rgba(139, 94, 60, 0.08);"
            data-filter="all"
          >
            All Stories
          </button>
          {categories.map(cat => (
            <button 
              class="filter-btn font-sans text-xs tracking-[0.2em] uppercase px-4 py-2 rounded-full border transition-all duration-300 whitespace-nowrap"
              style="border-color: rgba(10, 41, 71, 0.2); color: rgba(10, 41, 71, 0.6);"
              data-filter={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Stories Grid — Masonry-style with varying sizes -->
    <section class="py-16 md:py-24" style="background-color: #F3E4C9;">
      <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" id="stories-grid">
          {stories.map((story, i) => (
            <a 
              href={`/story/${story.slug}`}
              class={`story-archive-card group relative overflow-hidden rounded-sm ${i === 0 || i === 3 ? 'md:col-span-2 lg:col-span-1' : ''} ${i === 1 ? 'lg:row-span-2' : ''}`}
              data-category={story.category}
            >
              <div class={`relative overflow-hidden ${i === 1 ? 'aspect-3/4' : 'aspect-4/3'}`} style="background-color: rgba(10, 41, 71, 0.05);">
                <img 
                  src={story.coverImage}
                  alt={story.couple}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                  loading="lazy"
                  onerror="this.src='/images/hero-bg.jpeg'"
                />
                <!-- Overlay -->
                <div class="absolute inset-0 opacity-80 group-hover:opacity-90 transition-opacity duration-500" style="background: linear-gradient(to top, #0A2947, rgba(10, 41, 71, 0.2), transparent);"></div>
                
                <!-- Content -->
                <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
                  <p class="font-sans text-[10px] tracking-[0.3em] uppercase mb-2 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500" style="color: #D3D4C0;">
                    {story.category}
                  </p>
                  <h3 class="font-serif text-xl md:text-2xl font-light leading-tight mb-2" style="color: #F3E4C9;">
                    {story.title}
                  </h3>
                  <p class="font-sans text-sm mb-4 line-clamp-2" style="color: rgba(243, 228, 201, 0.6);">
                    {story.subtitle}
                  </p>
                  <div class="flex items-center gap-2 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-100">
                    <span class="font-sans text-[10px] tracking-[0.2em] uppercase" style="color: #8B5E3C;">View Story</span>
                    <svg class="w-3 h-3" style="color: #8B5E3C;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </div>
                </div>

                <!-- Corner accent -->
                <div class="absolute top-4 right-4 w-8 h-8 border-t border-r opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="border-color: rgba(243, 228, 201, 0.3);"></div>
                <div class="absolute bottom-4 left-4 w-8 h-8 border-b border-l opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="border-color: rgba(243, 228, 201, 0.3);"></div>
              </div>
            </a>
          ))}
        </div>

        <!-- Empty state (hidden by default) -->
        <div id="empty-state" class="hidden text-center py-20">
          <p class="font-serif text-2xl" style="color: rgba(10, 41, 71, 0.3);">No stories found in this category.</p>
        </div>
      </div>
    </section>

    <!-- CTA Section — CHANGED TO SAGE TINT -->
    <section class="border-t py-20 md:py-28" style="background-color: #D3D4C0; border-color: rgba(10, 41, 71, 0.08);">
      <div class="max-w-7xl mx-auto px-6 md:px-12 text-center">
        <p class="font-serif text-2xl md:text-3xl font-light italic mb-8" style="color: rgba(10, 41, 71, 0.5);">
          "Every love story is beautiful, but yours is my favorite."
        </p>
        <a 
          href="/" 
          class="inline-flex items-center gap-3 px-8 py-4 border font-sans text-sm tracking-[0.2em] uppercase transition-all duration-300"
          style="border-color: #8B5E3C; color: #0A2947;"
        >
          Back to Home
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .archive-fade-in {
    opacity: 0;
    transform: translateY(30px);
    animation: archiveFadeIn 1s ease-out forwards;
  }
  
  .archive-delay-1 { animation-delay: 0.2s; }
  .archive-delay-2 { animation-delay: 0.4s; }
  .archive-delay-3 { animation-delay: 0.6s; }
  
  @keyframes archiveFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .filter-btn.active {
    border-color: #8B5E3C !important;
    color: #0A2947 !important;
    background: rgba(139, 94, 60, 0.08) !important;
  }

  .filter-btn:hover {
    border-color: #8B5E3C !important;
    color: #0A2947 !important;
  }

  /* Card entrance animation */
  .story-archive-card {
    opacity: 0;
    transform: translateY(40px);
    animation: cardEnter 0.8s ease-out forwards;
  }
  
  .story-archive-card:nth-child(1) { animation-delay: 0.1s; }
  .story-archive-card:nth-child(2) { animation-delay: 0.2s; }
  .story-archive-card:nth-child(3) { animation-delay: 0.3s; }
  .story-archive-card:nth-child(4) { animation-delay: 0.4s; }
  
  @keyframes cardEnter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hide filtered out cards */
  .story-archive-card.hidden-card {
    display: none;
  }
</style>

<script>
  // @ts-nocheck
  // Filter functionality
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.story-archive-card');
    const emptyState = document.getElementById('empty-state');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        
        // Update active state
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        // Filter cards
        let visibleCount = 0;
        cards.forEach(card => {
          const category = card.dataset.category;
          if (filter === 'all' || category === filter) {
            card.classList.remove('hidden-card');
            visibleCount++;
          } else {
            card.classList.add('hidden-card');
          }
        });
        
        // Show/hide empty state
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
        } else {
          emptyState.classList.add('hidden');
        }
      });
    });
  });
</script>